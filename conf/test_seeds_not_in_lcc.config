/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run nf-core/diseasemodulediscovery -profile test_seeds_not_in_lcc,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus: 2,
        memory: '6.GB',
        time: '1.h'
    ]
    memory = { 1.GB * task.attempt }
    withLabel:process_single {
        cpus   = { 1                   }
        memory = { 1.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }
    withLabel:process_low {
        cpus   = { 2     * task.attempt }
        memory = { 1.GB  * task.attempt }
        time   = { 4.h   * task.attempt }
    }
    withName: DIGEST {
        memory = 6.GB
    }
}

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Tests pipeline function with no seeds in the largest connected component (LCC) of the PPI network (https://github.com/nf-core/diseasemodulediscovery/issues/149)'

    // Input data
    seeds                   = "https://raw.githubusercontent.com/nf-core/test-datasets/diseasemodulediscovery/issue_149/mondo.0009025.tsv"
    network                 = "https://raw.githubusercontent.com/nf-core/test-datasets/diseasemodulediscovery/issue_149/string.human_physical_links_v12_0_min700.Entrez.csv"
    skip_diamond            = true
    skip_domino             = true
    skip_firstneighbor      = true
    skip_robust             = true
    skip_robust_bias_aware  = true
    skip_evaluation         = true
    skip_drug_predictions   = true
    skip_drugstone_export   = true
    skip_visualization      = true
    skip_annotation         = true
}
